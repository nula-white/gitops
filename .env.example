# =============================================================================
# PRISM — .env  (copy to prism/ root, never commit to git)
# =============================================================================
# This file is read by pydantic-settings at startup.
# Every value here can be overridden by a real environment variable.
# =============================================================================


# ── GitHub Fine-Grained Personal Access Token ─────────────────────────────────
#
# SETUP STEPS:
#   1. Go to https://github.com/settings/tokens?type=beta
#   2. Click "Generate new token"
#   3. Token name: "PRISM analysis token"
#   4. Expiration: 90 days (rotate regularly)
#   5. Repository access: "Only select repositories" → choose the target repo
#      OR "All repositories" for broad analysis capability
#   6. Permissions — set ONLY these (principle of least privilege):
#        Repository permissions:
#          Contents:        Read-only   ← clone + file read
#          Metadata:        Read-only   ← repo info (auto-selected)
#   7. Click "Generate token" → copy the value starting with github_pat_
#   8. Paste it below. The token is used by ingestion/pipeline.py and
#      never logged, stored to disk, or passed in subprocess arguments.
#
# The token is stored here as PRISM_GIT_TOKEN.
# ingestion/credential_provider.py reads it via EnvCredentialProvider,
# which wraps it in a SecureString and zeros memory after use.
#
PRISM_GIT_TOKEN=github_pat_REPLACE_WITH_YOUR_TOKEN


# ── Neo4j ─────────────────────────────────────────────────────────────────────
#
# SETUP STEPS:
#   Option A — Docker (recommended for development):
#     docker run -d \
#       --name prism-neo4j \
#       -p 7474:7474 -p 7687:7687 \
#       -e NEO4J_AUTH=neo4j/your_password_here \
#       -e NEO4J_PLUGINS='["apoc"]' \
#       neo4j:5.18
#     Then open http://localhost:7474 and verify connection.
#
#   Option B — Neo4j Desktop:
#     Download from https://neo4j.com/download/
#     Create a new project → Add local DBMS → set password below
#
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j


# ── Joern (CFG + DFG graph construction) ─────────────────────────────────────
#
# SETUP STEPS:
#   1. Install Java 11+ first:
#        Ubuntu/Debian: sudo apt install openjdk-11-jdk
#        macOS:         brew install openjdk@11
#        Windows:       https://adoptium.net/
#      Verify: java -version
#
#   2. Download Joern:
#        mkdir -p ~/tools && cd ~/tools
#        wget https://github.com/joernio/joern/releases/latest/download/joern-cli.zip
#        unzip joern-cli.zip
#        # This creates ~/tools/joern-cli/
#
#   3. Add to PATH (or set JOERN_HOME below):
#        echo 'export JOERN_HOME=$HOME/tools/joern-cli' >> ~/.bashrc
#        echo 'export PATH=$JOERN_HOME/bin:$PATH' >> ~/.bashrc
#        source ~/.bashrc
#
#   4. Verify: joern-parse --version
#
#   5. Set ENABLE_JOERN=true once joern-parse is on PATH.
#
# Windows path example: JOERN_HOME=C:\tools\joern-cli
# JOERN_HOME is optional if joern-parse is on PATH.
#
ENABLE_JOERN=true
JOERN_HOME=/home/YOUR_USER/tools/joern-cli
JOERN_TIMEOUT=300
JOERN_MAX_HEAP=4G


# ── CodeQL (SARIF security annotation) ───────────────────────────────────────
#
# SETUP STEPS:
#   1. Download CodeQL CLI bundle (includes queries):
#        cd ~/tools
#        # Find latest release at: https://github.com/github/codeql-action/releases
#        # Download codeql-bundle-linux64.tar.gz (Linux) or codeql-bundle-osx64.tar.gz (macOS)
#        wget https://github.com/github/codeql-action/releases/latest/download/codeql-bundle-linux64.tar.gz
#        tar xzf codeql-bundle-linux64.tar.gz
#        # This creates ~/tools/codeql-home/ containing:
#        #   codeql/          ← CLI binary + packed queries
#        #   codeql-repo/     ← query source (for custom queries)
#
#   2. Verify: ~/tools/codeql-home/codeql/codeql version
#
#   3. Set paths below:
#
# Windows:
#   CODEQL_CLI_PATH=C:\tools\codeql-home\codeql\codeql.exe
#   CODEQL_SEARCH_PATH=C:\tools\codeql-home\codeql
#
CODEQL_CLI_PATH=/home/YOUR_USER/tools/codeql-home/codeql/codeql
CODEQL_SEARCH_PATH=/home/YOUR_USER/tools/codeql-home/codeql


# ── gVisor (microVM sandbox isolation) ───────────────────────────────────────
#
# SETUP STEPS (Linux only — gVisor does not run on macOS/Windows natively):
#
#   1. Install gVisor (runsc):
#        # Add gVisor apt repo
#        sudo apt-get install -y apt-transport-https ca-certificates curl gnupg
#        curl -fsSL https://gvisor.dev/archive.key | sudo gpg --dearmor -o /usr/share/keyrings/gvisor-archive-keyring.gpg
#        echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/gvisor-archive-keyring.gpg] https://storage.googleapis.com/gvisor/releases release main" | sudo tee /etc/apt/sources.list.d/gvisor.list
#        sudo apt-get update && sudo apt-get install -y runsc
#
#   2. Configure Docker to use runsc runtime:
#        # Add to /etc/docker/daemon.json:
#        {
#          "runtimes": {
#            "runsc": {
#              "path": "/usr/local/bin/runsc"
#            }
#          }
#        }
#        sudo systemctl restart docker
#
#   3. Verify:
#        docker run --runtime=runsc hello-world
#
#   4. If gVisor is not available, PRISM degrades gracefully to standard Docker
#      (no runsc) and logs a warning. The analysis still runs correctly —
#      only the microVM isolation layer is missing.
#
# No .env variable needed — gVisor availability is detected at runtime
# by checking Docker's registered runtimes for "runsc".


# ── HashiCorp Vault (for production secret management) ─────────────
#
# See vault/README.md for full setup instructions.
# Leave blank to use PRISM_GIT_TOKEN from this .env file instead.
#
VAULT_ADDR=http://127.0.0.1:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_TOKEN=


# ── Pipeline limits ───────────────────────────────────────────────────────────
MAX_REPO_MB=100
MAX_FILE_SIZE_MB=10
SANDBOX_TIMEOUT_SECONDS=300
PIPELINE_TIMEOUT_S=600


# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5001
DEBUG=false

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=15
